<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Urso Tricolor — Media Kit 2025/2026</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --verde: #1B5E20;
  --verde-claro: #2E7D32;
  --verde-brilho: #66BB6A;
  --grena: #8B1A1A;
  --grena-claro: #B22222;
  --grena-brilho: #D94040;
  --branco: #F5F0E8;
  --ouro: #C8A84B;
  --preto: #080808;
  --cinza: #1A1A1A;
  --texto: #D0C8BC;
  --texto-sec: #B0A898;
}
html { scroll-behavior:smooth; }
body {
  background: var(--preto);
  color: var(--branco);
  font-family: 'DM Sans', sans-serif;
  overflow: hidden;
  height: 100vh;
  width: 100vw;
}
.deck { width:100%; height:100vh; position:relative; }
.slide {
  position:absolute; inset:0; display:flex;
  opacity:0; pointer-events:none;
  transition:opacity 0.65s ease; overflow:hidden;
}
.slide.active { opacity:1; pointer-events:all; }

/* STRIPES */
.stripe-bg { position:absolute; inset:0; overflow:hidden; z-index:0; }
.stripe-bg::before {
  content:''; position:absolute; top:-20%; left:-10%;
  width:40px; height:200%;
  background:var(--grena); opacity:0.08; transform:rotate(8deg);
  box-shadow: 65px 0 0 var(--verde), 130px 0 0 var(--grena), 195px 0 0 var(--verde), 260px 0 0 var(--grena), 325px 0 0 var(--verde), 390px 0 0 var(--grena), 455px 0 0 var(--verde), 520px 0 0 var(--grena), 585px 0 0 var(--verde), 650px 0 0 var(--grena), 715px 0 0 var(--verde), 780px 0 0 var(--grena), 845px 0 0 var(--verde), 910px 0 0 var(--grena), 975px 0 0 var(--verde), 1040px 0 0 var(--grena), 1105px 0 0 var(--verde), 1170px 0 0 var(--grena);
}

/* NAV */
.nav {
  position:fixed; bottom:28px; left:50%; transform:translateX(-50%);
  z-index:1000; display:flex; gap:10px; align-items:center;
  background:rgba(5,5,5,0.85); padding:10px 20px; border-radius:50px;
  border:1px solid rgba(200,168,75,0.25); backdrop-filter:blur(12px);
}
.dot { width:8px; height:8px; border-radius:50%; background:#333; cursor:pointer; transition:all 0.3s; border:1px solid #555; }
.dot.active { background:var(--ouro); transform:scale(1.4); border-color:var(--ouro); }
.dot:hover { background:var(--grena-brilho); border-color:var(--grena-brilho); }
.nav-btn { background:none; border:1px solid rgba(200,168,75,0.35); color:var(--ouro); width:30px; height:30px; border-radius:50%; cursor:pointer; font-size:13px; transition:all 0.3s; display:flex; align-items:center; justify-content:center; }
.nav-btn:hover { background:var(--grena); color:var(--branco); border-color:var(--grena); }
.slide-counter { font-family:'Bebas Neue'; font-size:13px; color:var(--ouro); letter-spacing:2px; min-width:40px; text-align:center; }
.key-hint { position:fixed; bottom:80px; right:28px; font-size:10px; color:#3a3a3a; letter-spacing:2px; text-transform:uppercase; z-index:100; }

/* SHARED LAYOUT */
.tag { font-size:12px; letter-spacing:5px; text-transform:uppercase; color:var(--ouro); margin-bottom:20px; display:flex; align-items:center; gap:12px; }
.tag::before { content:''; width:28px; height:1px; background:var(--ouro); display:block; }
.section-tag { font-size:12px; letter-spacing:5px; text-transform:uppercase; color:var(--ouro); margin-bottom:16px; }
.section-title { font-family:'Bebas Neue'; font-size:clamp(44px,4.5vw,72px); line-height:0.9; color:var(--branco); margin-bottom:36px; }
.section-title span { color:var(--grena-brilho); }
.two-col { display:flex; width:100%; height:100%; }
.img-panel { width:42%; height:100%; overflow:hidden; position:relative; flex-shrink:0; }
.img-panel img { width:100%; height:100%; object-fit:cover; object-position:center top; }
.img-panel::after { content:''; position:absolute; right:0; top:0; bottom:0; width:120px; background:linear-gradient(to right,transparent,var(--preto)); z-index:2; }
.content-panel { flex:1; padding:52px 64px 52px 44px; display:flex; flex-direction:column; justify-content:center; z-index:2; }

/* ANIMATIONS */
.slide.active .animate-in { animation:slideUp 0.65s cubic-bezier(0.16,1,0.3,1) forwards; }
@keyframes slideUp { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
.delay-1 { animation-delay:0.08s; opacity:0; }
.delay-2 { animation-delay:0.18s; opacity:0; }
.delay-3 { animation-delay:0.28s; opacity:0; }
.delay-4 { animation-delay:0.38s; opacity:0; }
.delay-5 { animation-delay:0.48s; opacity:0; }
.delay-6 { animation-delay:0.58s; opacity:0; }

/* ══ SLIDE 1: CAPA ══ */
#s1 { background:linear-gradient(140deg,#060606 0%,#0e1c0e 45%,#1a0606 100%); align-items:center; }
#s1 .left { flex:1; padding:60px 36px 60px 64px; display:flex; flex-direction:column; justify-content:center; z-index:2; }
#s1 .right { width:44%; height:100%; position:relative; overflow:hidden; flex-shrink:0; }
#s1 .right img { width:100%; height:100%; object-fit:cover; object-position:top center; filter:brightness(0.92) contrast(1.08); }
#s1 .right::before { content:''; position:absolute; left:0; top:0; bottom:0; width:140px; background:linear-gradient(to right,#060606,transparent); z-index:2; }
.capa-title { font-family:'Bebas Neue'; font-size:clamp(70px,9vw,120px); line-height:0.86; color:var(--branco); margin-bottom:4px; }
.capa-title .verde { color:var(--verde-brilho); display:block; }
.capa-sub { font-size:16px; color:var(--texto); margin-top:22px; margin-bottom:42px; max-width:430px; line-height:1.75; font-weight:400; }
.capa-platforms { display:flex; gap:28px; align-items:center; }
.plat-badge { display:flex; flex-direction:column; gap:5px; }
.plat-num { font-family:'Bebas Neue'; font-size:42px; line-height:1; color:var(--ouro); }
.plat-label { font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--texto-sec); }
.divider-v { width:1px; background:#2a2a2a; align-self:stretch; margin:4px 0; }
.total-views { margin-top:36px; padding-top:28px; border-top:1px solid #1e1e1e; display:flex; align-items:baseline; gap:14px; }
.total-num { font-family:'Bebas Neue'; font-size:60px; line-height:1; color:var(--verde-brilho); }
.total-label { font-size:14px; letter-spacing:2px; text-transform:uppercase; color:var(--texto-sec); max-width:130px; line-height:1.5; }

/* ══ SLIDE 2: PERSONAGEM ══ */
#s2 { background:var(--preto); }
.body-text { font-size:16px; line-height:1.85; color:var(--texto); margin-bottom:14px; max-width:500px; }
.body-text strong { color:var(--branco); font-weight:600; }
.feature-list { margin-top:28px; display:flex; flex-direction:column; gap:12px; }
.feature-item { display:flex; align-items:flex-start; gap:16px; padding:14px 18px; background:rgba(139,26,26,0.12); border-left:3px solid var(--grena-claro); }
.feature-icon { font-size:18px; flex-shrink:0; margin-top:2px; }
.feature-text { font-size:15px; line-height:1.65; color:var(--texto); }
.feature-text strong { color:var(--branco); display:block; margin-bottom:3px; font-weight:600; }

/* ══ SLIDE 3: ALCANCE ══ */
#s3 { background:linear-gradient(155deg,#090f09 0%,#060606 55%,#100606 100%); flex-direction:column; justify-content:center; padding:44px 64px; }
.metrics-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:3px; margin-top:32px; }
.metric-card { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); padding:32px 28px; position:relative; overflow:hidden; transition:background 0.3s; }
.metric-card:hover { background:rgba(255,255,255,0.055); }
.metric-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
.metric-card.tiktok::before { background:linear-gradient(to right,#ff0050,#ff3870); }
.metric-card.youtube::before { background:linear-gradient(to right,#ff0000,#cc0000); }
.metric-card.instagram::before { background:linear-gradient(to right,#833ab4,#fd1d1d,#fcb045); }
.plat-name { font-size:11px; letter-spacing:4px; text-transform:uppercase; color:var(--texto-sec); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.plat-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.tiktok .plat-dot { background:#ff0050; }
.youtube .plat-dot { background:#ff0000; }
.instagram .plat-dot { background:#fd1d1d; }
.big-num { font-family:'Bebas Neue'; font-size:clamp(50px,4.5vw,72px); line-height:0.9; color:var(--branco); margin-bottom:4px; }
.big-label { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--texto-sec); margin-bottom:22px; }
.stat-rows { display:flex; flex-direction:column; gap:9px; border-top:1px solid rgba(255,255,255,0.07); padding-top:16px; }
.stat-row { display:flex; justify-content:space-between; align-items:baseline; }
.stat-label { font-size:12px; color:var(--texto-sec); letter-spacing:1px; text-transform:uppercase; }
.stat-val { font-family:'Bebas Neue'; font-size:20px; color:var(--ouro); }
.stat-note { font-size:11px; color:var(--texto-sec); line-height:1.5; margin-top:6px; padding-top:6px; border-top:1px solid rgba(255,255,255,0.05); }
.total-strip { margin-top:20px; background:var(--grena); padding:16px 28px; display:flex; justify-content:space-between; align-items:center; }
.strip-label { font-size:12px; letter-spacing:3px; text-transform:uppercase; color:rgba(245,240,232,0.8); }
.strip-num { font-family:'Bebas Neue'; font-size:36px; color:var(--branco); line-height:1; }

/* ══ SLIDE 4: POR QUE ══ */
#s4 { background:var(--preto); flex-direction:column; justify-content:center; padding:44px 64px; }
.why-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:3px; margin-top:32px; }
.why-card { background:rgba(139,26,26,0.08); padding:32px 28px; position:relative; overflow:hidden; border:1px solid rgba(139,26,26,0.2); transition:background 0.3s; }
.why-card:hover { background:rgba(139,26,26,0.16); }
.why-card::before { content:attr(data-num); position:absolute; top:-8px; right:14px; font-family:'Bebas Neue'; font-size:90px; color:rgba(139,26,26,0.08); line-height:1; pointer-events:none; }
.why-icon { font-size:26px; margin-bottom:14px; }
.why-title { font-family:'Playfair Display'; font-weight:700; font-size:19px; color:var(--branco); margin-bottom:10px; line-height:1.25; }
.why-text { font-size:15px; line-height:1.75; color:var(--texto); }
.why-text strong { color:var(--verde-brilho); font-weight:600; }

/* ══ SLIDE 5: PÚBLICO ══ */
#s5 { background:linear-gradient(135deg,#080808,#0c160c); }
.audience-items { display:flex; flex-direction:column; gap:14px; margin-top:28px; }
.audience-card { display:flex; align-items:flex-start; gap:18px; padding:16px 18px; background:rgba(139,26,26,0.1); border:1px solid rgba(139,26,26,0.22); }
.aud-icon { font-size:22px; flex-shrink:0; }
.aud-text { font-size:15px; line-height:1.7; color:var(--texto); }
.aud-text strong { color:var(--branco); display:block; margin-bottom:3px; font-size:15px; font-weight:600; }

/* ══ SLIDE 6: FORMATOS ══ */
#s6 { background:var(--preto); flex-direction:column; padding:44px 64px; justify-content:center; }
.formats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:3px; margin-top:32px; }
.format-card { background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.06); padding:26px 22px; transition:all 0.3s; position:relative; overflow:hidden; }
.format-card:hover { background:rgba(139,26,26,0.15); border-color:rgba(178,34,34,0.4); transform:translateY(-3px); }
.format-num { font-family:'Bebas Neue'; font-size:44px; color:rgba(178,34,34,0.2); line-height:1; margin-bottom:6px; }
.format-title { font-family:'Playfair Display'; font-size:17px; font-weight:700; color:var(--ouro); margin-bottom:10px; }
.format-text { font-size:14px; line-height:1.75; color:var(--texto); }
.format-text strong { color:var(--verde-brilho); font-weight:600; }

/* ══ SLIDE 7: PORTFÓLIO ══ */
#s7 { background:var(--preto); flex-direction:column; padding:40px 48px 80px; justify-content:flex-start; }
.portfolio-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:5px; margin-top:24px; flex:1; }
.portfolio-item { height: calc(100vh - 240px); min-height: 340px; overflow:hidden; position:relative; cursor:default; }
.portfolio-item img { width:100%; height:100%; object-fit:cover; object-position:top center; transition:transform 0.5s ease; filter:brightness(0.9) saturate(0.95); }
.portfolio-item:hover img { transform:scale(1.05); filter:brightness(1.05) saturate(1.1); }
.portfolio-item::after { content:''; position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.55),transparent 55%); }

/* ══ SLIDE 8: CONTATO ══ */
#s8 { background:linear-gradient(140deg,#060606 0%,#0b180b 50%,#060606 100%); align-items:center; justify-content:center; flex-direction:column; text-align:center; }
.contact-logo { font-family:'Bebas Neue'; font-size:90px; line-height:0.86; color:var(--branco); margin-bottom:12px; letter-spacing:3px; }
.contact-logo span { color:var(--grena-brilho); }
.contact-sub { font-size:13px; letter-spacing:5px; text-transform:uppercase; color:var(--texto-sec); margin-bottom:44px; }
.contact-items { display:flex; gap:52px; margin-bottom:44px; align-items:center; }
.contact-item { display:flex; flex-direction:column; align-items:center; gap:7px; }
.contact-type { font-size:11px; letter-spacing:4px; text-transform:uppercase; color:var(--texto-sec); }
.contact-val { font-size:19px; color:var(--ouro); font-weight:500; }
.divider-h { width:1px; height:44px; background:#1e1e1e; align-self:center; }
.cta-line { font-size:13px; color:#4a4a4a; letter-spacing:3px; text-transform:uppercase; margin-bottom:36px; }

/* SOCIAL ICONS */
.social-row { display:flex; gap:20px; margin-bottom:0; }
.soc {
  display:flex; flex-direction:column; align-items:center; gap:10px;
  padding:18px 28px;
  border:1px solid rgba(139,26,26,0.3);
  background:rgba(139,26,26,0.08);
  text-decoration:none;
  color:var(--texto);
  transition:all 0.3s;
  min-width:110px;
  cursor:pointer;
}
.soc:hover {
  border-color:var(--grena-claro);
  background:rgba(139,26,26,0.22);
  color:var(--branco);
  transform:translateY(-3px);
}
.soc svg { transition:transform 0.3s; }
.soc:hover svg { transform:scale(1.15); }
.soc-label { font-size:11px; letter-spacing:3px; text-transform:uppercase; color:inherit; }
.soc-handle { font-size:13px; color:var(--texto-sec); }
.soc:hover .soc-handle { color:var(--ouro); }

.bottom-footer { position:absolute; bottom:90px; left:0; right:0; text-align:center; font-size:12px; color:#2e2e2e; letter-spacing:2px; text-transform:uppercase; }

/* ═══════════════════════════════════════════
   MOBILE RESPONSIVE — max-width: 768px
   Desktop layout is untouched above
═══════════════════════════════════════════ */
@media (max-width: 768px) {
  /* Global */
  body { overflow: hidden; }
  
  .key-hint { display: none; }
  
  .nav {
    bottom: 16px;
    padding: 8px 14px;
    gap: 7px;
  }
  .dot { width: 6px; height: 6px; }
  .nav-btn { width: 26px; height: 26px; font-size: 11px; }
  .slide-counter { font-size: 11px; min-width: 32px; }

  /* All slides: stack vertically, scrollable inside */
  .slide {
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 70px;
  }

  /* Stripe bg less aggressive on mobile */
  .stripe-bg::before { opacity: 0.04; }

  /* ── SLIDE 1: CAPA ── */
  #s1 {
    flex-direction: column;
    justify-content: flex-start;
    padding: 0;
  }
  #s1 .right {
    width: 100%;
    height: 52vw;
    max-height: 280px;
    flex-shrink: 0;
    order: -1;
  }
  #s1 .right::before {
    width: 0;
    background: none;
  }
  #s1 .right img { object-position: top center; }
  #s1 .right::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #060606);
    z-index: 2;
  }
  #s1 .left {
    flex: none;
    padding: 20px 24px 16px;
    width: 100%;
  }
  .capa-title { font-size: clamp(52px, 14vw, 72px); line-height: 0.88; margin-bottom: 4px; }
  .capa-sub { font-size: 13px; margin-top: 14px; margin-bottom: 24px; max-width: 100%; }
  .capa-platforms { gap: 20px; flex-wrap: wrap; }
  .plat-num { font-size: 32px; }
  .plat-label { font-size: 8px; }
  .total-views { margin-top: 20px; padding-top: 18px; }
  .total-num { font-size: 44px; }
  .total-label { font-size: 10px; }
  .tag { font-size: 9px; margin-bottom: 14px; }

  /* ── SLIDE 2: PERSONAGEM ── */
  #s2 { flex-direction: column; overflow-y: auto; }
  .two-col { flex-direction: column; height: auto; min-height: 100%; }
  .img-panel {
    width: 100%;
    height: 56vw;
    max-height: 300px;
    flex-shrink: 0;
  }
  .img-panel::after {
    right: 0; top: auto;
    width: 100%; height: 80px;
    background: linear-gradient(to bottom, transparent, var(--preto));
    bottom: 0; left: 0;
  }
  #s5 .img-panel::after { background: linear-gradient(to bottom, transparent, #0c160c); }
  .content-panel {
    flex: none;
    padding: 20px 24px 16px;
    width: 100%;
  }
  .section-title { font-size: clamp(36px, 10vw, 52px); margin-bottom: 20px; }
  .body-text { font-size: 13px; max-width: 100%; margin-bottom: 12px; }
  .feature-list { margin-top: 16px; gap: 10px; }
  .feature-item { padding: 12px 14px; gap: 12px; }
  .feature-icon { font-size: 16px; }
  .feature-text { font-size: 12px; }

  /* ── SLIDE 3: ALCANCE ── */
  #s3 {
    padding: 24px 20px 16px;
    flex-direction: column;
    overflow-y: auto;
    justify-content: flex-start;
  }
  .metrics-grid {
    grid-template-columns: 1fr;
    gap: 3px;
    margin-top: 20px;
  }
  .metric-card { padding: 20px 18px; }
  .big-num { font-size: 52px; }
  .stat-rows { gap: 7px; padding-top: 12px; }
  .stat-label { font-size: 9px; }
  .stat-val { font-size: 17px; }
  .stat-note { font-size: 8px; }
  .total-strip {
    margin-top: 12px;
    padding: 14px 18px;
    flex-direction: column;
    gap: 4px;
    text-align: center;
  }
  .strip-label { font-size: 9px; letter-spacing: 2px; }
  .strip-num { font-size: 28px; }
  #s3 .section-title { margin-bottom: 0; }

  /* ── SLIDE 4: POR QUE ── */
  #s4 {
    padding: 24px 20px 16px;
    overflow-y: auto;
    justify-content: flex-start;
  }
  .why-grid {
    grid-template-columns: 1fr;
    gap: 3px;
    margin-top: 20px;
  }
  .why-card { padding: 20px 18px; }
  .why-card::before { font-size: 70px; top: -6px; right: 10px; }
  .why-icon { font-size: 22px; margin-bottom: 10px; }
  .why-title { font-size: 15px; margin-bottom: 8px; }
  .why-text { font-size: 12px; line-height: 1.65; }
  #s4 .section-title { margin-bottom: 0; }

  /* ── SLIDE 5: PÚBLICO ── */
  #s5 { flex-direction: column; overflow-y: auto; }
  #s5 .two-col { flex-direction: column; }
  #s5 .content-panel { padding: 20px 24px 16px; }
  .audience-items { gap: 10px; margin-top: 16px; }
  .audience-card { padding: 12px 14px; gap: 14px; }
  .aud-icon { font-size: 18px; }
  .aud-text { font-size: 12px; }

  /* ── SLIDE 6: FORMATOS ── */
  #s6 {
    padding: 24px 20px 16px;
    overflow-y: auto;
    justify-content: flex-start;
  }
  .formats-grid {
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    margin-top: 20px;
  }
  .format-card { padding: 18px 14px; }
  .format-num { font-size: 34px; margin-bottom: 4px; }
  .format-title { font-size: 13px; margin-bottom: 8px; }
  .format-text { font-size: 11px; line-height: 1.6; }
  #s6 .section-title { margin-bottom: 0; }

  /* ── SLIDE 7: PORTFÓLIO ── */
  #s7 {
    padding: 24px 16px 16px;
    overflow-y: auto;
    justify-content: flex-start;
  }
  .portfolio-grid {
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    margin-top: 16px;
  }
  .portfolio-item {
    height: 44vw;
    min-height: 140px;
  }
  #s7 .section-title { margin-bottom: 0; font-size: clamp(32px, 9vw, 48px); }

  /* ── SLIDE 8: CONTATO ── */
